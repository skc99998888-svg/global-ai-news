# Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI API 配置
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_API_KEY=your-ai-api-key

# 说明
# NEXT_PUBLIC_SUPABASE_URL — Supabase 项目 URL（公开）
# SUPABASE_SERVICE_ROLE_KEY — 服务端密钥，勿在前端使用
# AI_PROVIDER — AI 提供商标识（记录用）
# AI_BASE_URL — API 端点，OpenAI 填 https://api.openai.com/v1
# AI_MODEL — 模型名称
# AI_API_KEY — AI API Key（仅服务端使用）
# 不配置 Supabase 时系统使用 Mock 数据
